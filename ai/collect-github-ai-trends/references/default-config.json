{
  "schema_version": 1,
  "document_language": "zh-CN",
  "timezone": "Asia/Shanghai",
  "window_hours": 72,
  "include_older_items": false,
  "request_timeout_seconds": 45,
  "request_retries": 1,
  "cache_max_age_hours": 24,
  "reddit": {"enabled": false},
  "x": {"enabled": false, "topic_queries": []},
  "github": {
    "enabled": true,
    "queries": [
      "created:>={since_date} topic:llm",
      "created:>={since_date} topic:artificial-intelligence",
      "created:>={since_date} topic:machine-learning",
      "pushed:>={since_date} topic:generative-ai stars:>500",
      "created:>={since_date} topic:coding-agents",
      "created:>={since_date} topic:ai-coding-agent",
      "created:>={since_date} topic:ai-coding-assistant"
    ],
    "limit_per_query": 20
  },
  "ranking": {
    "source_weights": {"github": 1.0},
    "cross_source_bonus": 0.0,
    "cluster_similarity": 0.52,
    "report_topic_count": 10
  },
  "drafts": {
    "language": "zh-CN",
    "count": 10,
    "mode": "long",
    "min_prose_characters": 120,
    "max_prose_characters": 180,
    "min_recommendation_characters": 20,
    "max_recommendation_characters": 50,
    "max_hashtags": 1
  },
  "obsidian": {
    "enabled": true,
    "vault": "wiki",
    "target_directory": "raw",
    "strict": true,
    "index_path": "index.md",
    "log_path": "log.md"
  }
}
