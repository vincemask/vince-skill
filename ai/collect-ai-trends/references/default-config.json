{
  "schema_version": 1,
  "document_language": "zh-CN",
  "timezone": "Asia/Shanghai",
  "window_hours": 72,
  "include_older_items": false,
  "request_timeout_seconds": 45,
  "request_retries": 1,
  "cache_max_age_hours": 24,
  "reddit": {
    "enabled": true,
    "subreddits": [
      "LocalLLaMA",
      "MachineLearning",
      "artificial",
      "ChatGPT",
      "ChatGPTCoding",
      "AI_Agents"
    ],
    "sort": "hot",
    "time": "week",
    "limit_per_subreddit": 20
  },
  "x": {
    "enabled": true,
    "accounts": [
      "OpenAI",
      "AnthropicAI",
      "GoogleDeepMind",
      "MetaAI",
      "huggingface",
      "NVIDIAAI",
      "MistralAI",
      "karpathy",
      "AndrewYNg"
    ],
    "topic_queries": [
      "\"coding agent\" OR \"coding agents\" OR \"agentic coding\"",
      "\"AI coding\" OR \"AI coding assistant\" OR \"AI code generation\""
    ],
    "batch_size": 3,
    "limit_per_batch": 30,
    "limit_per_topic_query": 30,
    "top_by_engagement": 20,
    "exclude_replies": true,
    "exclude_retweets": true
  },
  "github": {
    "enabled": true,
    "queries": [
      "created:>={since_date} topic:llm",
      "created:>={since_date} topic:artificial-intelligence",
      "created:>={since_date} topic:machine-learning",
      "pushed:>={since_date} topic:generative-ai stars:>500",
      "created:>={since_date} topic:coding-agents",
      "created:>={since_date} topic:ai-coding-agent",
      "created:>={since_date} topic:ai-coding-assistant"
    ],
    "limit_per_query": 20
  },
  "ranking": {
    "source_weights": {
      "reddit": 1.0,
      "x": 1.0,
      "github": 1.0
    },
    "cross_source_bonus": 8.0,
    "cluster_similarity": 0.52,
    "report_topic_count": 10
  },
  "drafts": {
    "language": "zh-CN",
    "count": 10,
    "mode": "long",
    "min_prose_characters": 120,
    "max_prose_characters": 180,
    "min_recommendation_characters": 20,
    "max_recommendation_characters": 50,
    "max_hashtags": 1
  }
}
